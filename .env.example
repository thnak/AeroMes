# Copy this file to .env and fill in values before running docker-compose.ha.yml
# Never commit .env to git.

# Docker image to pull
IMAGE=ghcr.io/your-org/aeromes
TAG=latest

# Version metadata shown in the UI (injected at runtime)
APP_VERSION=1.3.0
BUILD_DATE=2026-06-13T00:00:00Z
COMMIT_SHA=

# SQL Server
SQL_SA_PASSWORD=YourSecurePassword@2026
SQL_CONNECTION_STRING=Server=sqlserver;Database=AeroMes;User Id=sa;Password=YourSecurePassword@2026;TrustServerCertificate=true;

# JWT — must be the same on all replicas; change after any compromise
JWT_KEY=change-this-to-a-random-secret-at-least-32-characters-long
